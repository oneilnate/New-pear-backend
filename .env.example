# Food Pod Backend — Environment Variables
# Copy to .env for local dev. Never commit .env.

# Database path (defaults to ./foodpod.db if not set)
FOODPOD_DB_PATH=./foodpod.db

# Media storage directory (defaults to ./media for local dev)
# In production: /srv/foodpod/media (set by systemd EnvironmentFile)
FOODPOD_MEDIA_DIR=./media

# Server port (defaults to 8787)
PORT=8787

# --- Secrets (set in /etc/foodpod/env in production, 0600) ---

# Gemini 1.5 Pro API key — used in F4 for vision+script generation
GEMINI_API_KEY=

# ElevenLabs API key — used in F4 for Sarah voice synthesis
ELEVENLABS_API_KEY=

# ElevenLabs voice ID for Sarah
ELEVENLABS_VOICE_ID=
