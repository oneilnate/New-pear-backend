# Food Pod Backend — Environment Variables
# Copy to .env for local dev. Never commit .env.

# Database path (defaults to ./foodpod.db if not set)
FOODPOD_DB_PATH=./foodpod.db

# Media storage directory (defaults to ./media for local dev)
# In production: /srv/foodpod/media (set by systemd EnvironmentFile)
FOODPOD_MEDIA_DIR=./media

# Server port (defaults to 8787)
PORT=8787

# --- Secrets (set in /etc/foodpod/env in production, 0600) ---

# Gemini 1.5 Pro API key — required for F4 vision+script generation.
# If not set: server starts normally but POST /api/pods/:id/complete returns 503.
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ElevenLabs API key — required for F4 Sarah voice TTS synthesis (F4-E2).
# If not set: POST /api/pods/:id/complete returns 503.
ELEVENLABS_API_KEY=

# ElevenLabs voice ID for Sarah voice
# Sarah = EXAVITQu4vr4xnSDxMaL  (eleven_turbo_v2_5, stability=0.5, similarity=0.75)
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
