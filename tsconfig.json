{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowJs": true,
    "types": ["bun-types"]
  },
  "include": ["src", "tests"],
  "exclude": ["node_modules", "dist"]
}
